<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>College Bus Transport Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>

<body class="dark-theme">
    <!-- Login Modal -->
    <div id="loginModal" class="auth-modal">
        <div class="auth-container">
            <div class="auth-card">
                <div class="auth-header">
                    <span class="logo-icon">🚌</span>
                    <h1>UniTransit Admin</h1>
                </div>
                <form id="loginForm" class="auth-form">
                    <div class="form-group">
                        <label>Admin ID</label>
                        <input type="text" id="adminId" placeholder="Enter Admin ID" required>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" id="adminPassword" placeholder="Enter Password" required>
                    </div>
                    <button type="submit" class="btn btn-primary">Login</button>
                </form>
                <p class="auth-hint">Default: admin / 12345</p>
            </div>
        </div>
    </div>

    <div id="app" style="display:none;">
        <nav class="navbar">
            <div class="nav-logo">
                <span class="logo-icon">🚌</span>
                <span class="logo-text">UniTransit <span class="admin-badge">Admin</span></span>
                <span class="logged-user">Logged in as: <span id="loggedUser">admin</span></span>
            </div>
            <ul class="nav-links">
                <li class="active" data-view="bus-entry">Bus Entry</li>
                <li data-view="edit-bus-list">Edit Bus List</li>
                <li data-view="admin-panel">Admin Panel</li>
                <li class="logout-btn" id="logoutBtn">Logout</li>
            </ul>
        </nav>

        <main class="content-container">
            <!-- Bus Entry View -->
            <section id="bus-entry-view" class="view active">
                <!-- Hero Section (New) -->
                <div class="hero-section">
                    <div class="hero-content">
                        <h1>Smart Transit Gateway</h1>
                        <p>Real-time AI surveillance & automated fleet tracking</p>
                    </div>
                </div>

                <div class="view-header">
                    <h2>Gate Monitoring</h2>
                    <p class="subtitle">Live camera feed with automatic LPR detection</p>
                </div>

                <div class="dashboard-grid">
                    <!-- Scanner Module -->
                    <div class="card scanner-card">
                        <div class="card-header">
                            <span class="status-indicator live">LIVE CAMERA</span>
                            <div class="mode-toggle">
                                <span class="active" id="modeEntry">ENTRY</span>
                                <span id="modeExit">EXIT</span>
                            </div>
                        </div>
                        <div class="scanner-viewport">
                            <video id="videoFeed" autoplay playsinline muted></video>
                            <div class="scan-overlay">
                                <div class="scan-line"></div>
                                <div class="scan-corners">
                                    <span></span><span></span><span></span><span></span>
                                </div>
                            </div>
                        </div>
                        <div class="scan-details" id="currentScan">
                            <div class="bus-profile-header">
                                <div class="bus-avatar">🚌</div>
                                <div class="bus-main-status">
                                    <h3 id="detectedBusTitle">Vehicle Profile</h3>
                                    <p id="scanStatus">Waiting for detection...</p>
                                </div>
                            </div>
                            <div class="scan-info-row">
                                <span class="label">Plate Detected</span>
                                <span class="value plate-badge" id="scannedPlate">--</span>
                            </div>
                            <div class="scan-info-row">
                                <span class="label">Serial / Route</span>
                                <span class="value" id="busRouteInfo">--</span>
                            </div>
                            <div class="scan-info-row">
                                <span class="label">Driver Name</span>
                                <span class="value" id="busDriverName">--</span>
                            </div>
                            <div class="scan-info-row">
                                <span class="label">Capacity</span>
                                <span class="value" id="busCapacity">--</span>
                            </div>
                        </div>
                        <div class="scanner-actions">
                            <button id="simulateScan" class="btn btn-primary">Start AI Scanning</button>
                        </div>
                    </div>

                    <!-- Live Tracking & Logs -->
                    <div class="tracking-column">
                        <!-- Stats Row -->
                        <div class="stats-grid">
                            <div class="stat-card">
                                <span class="stat-label">Buses Inside</span>
                                <span class="stat-value" id="countInside">0</span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-label">Total Entries</span>
                                <span class="stat-value" id="countTotalEntries">0</span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-label">Total Exits</span>
                                <span class="stat-value" id="countTotalExits">0</span>
                            </div>
                        </div>

                        <!-- Live Status Card -->
                        <div class="card live-status-card">
                            <div class="card-header">
                                <h2>Currently In Campus</h2>
                                <span class="badge-count" id="inCampusBadge">0</span>
                            </div>
                            <div class="live-fleet-list" id="liveFleetList">
                                <!-- Live bus items here -->
                                <p class="empty-state">No buses currently inside campus</p>
                            </div>
                        </div>

                        <!-- Log Table -->
                        <div class="card log-card">
                            <div class="card-header">
                                <h2>Traffic Log (<span id="currentDateDisplay">--</span>)</h2>
                            </div>
                            <div class="table-container">
                                <table class="data-table" id="busLogTable">
                                    <thead>
                                        <tr>
                                            <th>Type</th>
                                            <th>Plate</th>
                                            <th>ID</th>
                                            <th>Time</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Rows will be injected here -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Edit Bus List View (Hidden by default) -->
            <section id="edit-bus-list-view" class="view">
                <div class="view-header">
                    <h1>Edit Bus Fleet</h1>
                    <p class="subtitle">Manage college bus records and assignments</p>
                </div>

                <div class="card form-card">
                    <form id="addBusForm" class="admin-form">
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Plate Number</label>
                                <input type="text" placeholder="TN-29 BC-2341" required>
                            </div>
                            <div class="form-group">
                                <label>Serial Number</label>
                                <input type="text" placeholder="B90" required>
                            </div>
                            <div class="form-group">
                                <label>Route</label>
                                <input type="text" placeholder="Dharmapuri" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary">Add Bus to Fleet</button>
                    </form>
                </div>

                <div class="card fleet-card">
                    <table class="data-table" id="fleetTable">
                        <thead>
                            <tr>
                                <th>Plate</th>
                                <th>Serial</th>
                                <th>Route</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="plate-badge">TN-29 BC-2341</td>
                                <td>B90</td>
                                <td>Dharmapuri</td>
                                <td><button class="btn btn-icon">Edit</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Admin Panel View -->
            <section id="admin-panel-view" class="view">
                <div class="view-header">
                    <h1>Admin Control Panel</h1>
                    <p class="subtitle">Manage scanners, users, and system settings</p>
                </div>

                <div class="admin-grid">
                    <!-- Scanner Management -->
                    <div class="card admin-card">
                        <div class="card-header">
                            <h2>🔍 Scanner Management</h2>
                        </div>
                        <div class="card-content">
                            <form id="addScannerForm" class="admin-form">
                                <div class="form-group">
                                    <label>Scanner Name</label>
                                    <input type="text" id="scannerName" placeholder="e.g., Gate 1 Scanner" required>
                                </div>
                                <div class="form-group">
                                    <label>Location</label>
                                    <input type="text" id="scannerLocation" placeholder="e.g., Main Gate" required>
                                </div>
                                <button type="submit" class="btn btn-primary">Add Scanner</button>
                            </form>
                            <div class="scanner-list">
                                <h3>Active Scanners:</h3>
                                <div id="scannersList" class="items-list">
                                    <!-- Scanners added here -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- User Management -->
                    <div class="card admin-card">
                        <div class="card-header">
                            <h2>👤 User Administration</h2>
                        </div>
                        <div class="card-content">
                            <form id="createAdminForm" class="admin-form">
                                <div class="form-group">
                                    <label>New Admin ID</label>
                                    <input type="text" id="newAdminId" placeholder="Enter Admin ID" required>
                                </div>
                                <div class="form-group">
                                    <label>Password</label>
                                    <input type="password" id="newAdminPassword" placeholder="Enter Password" required>
                                </div>
                                <button type="submit" class="btn btn-primary">Create Admin User</button>
                            </form>
                            <div class="admin-list">
                                <h3>Admin Users:</h3>
                                <div id="adminUsersList" class="items-list">
                                    <!-- Admin users listed here -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Scanned Records -->
                    <div class="card admin-card full-width">
                        <div class="card-header">
                            <h2>📋 Scanned Number Plates Record</h2>
                        </div>
                        <div class="table-container">
                            <table class="data-table" id="scannedRecordsTable">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Number Plate</th>
                                        <th>Bus Serial</th>
                                        <th>Driver Name</th>
                                        <th>Type</th>
                                        <th>Scanner</th>
                                    </tr>
                                </thead>
                                <tbody id="scannedRecordsBody">
                                    <!-- Records added here -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- System Statistics -->
                    <div class="card admin-card">
                        <div class="card-header">
                            <h2>📊 System Statistics</h2>
                        </div>
                        <div class="stats-grid">
                            <div class="stat-card">
                                <span class="stat-label">Total Scans Today</span>
                                <span class="stat-value" id="totalScansToday">0</span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-label">Active Scanners</span>
                                <span class="stat-value" id="activeScanners">0</span>
                            </div>
                            <div class="stat-card">
                                <span class="stat-label">Admin Users</span>
                                <span class="stat-value" id="adminUsersCount">0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <div id="notification-area"></div>
    </div>
    <script type="module" src="/main.js"></script>
</body>

</html>